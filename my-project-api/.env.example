# RecipeBox API Environment Variables

# PostgreSQL Database URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Examples:
# Local: postgresql://postgres:password@localhost:5432/recipebox
# Neon: postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/recipebox?sslmode=require
DATABASE_URL="your_database_url_here"

# Server Port
PORT=5000

# ==========================================
# AI API Keys (Choose ONE - Groq is FREE!)
# ==========================================

# OPTION 1: Groq API Key (FREE - RECOMMENDED)
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY="your_groq_api_key_here"

# OPTION 2: OpenAI API Key (Paid)
OPENAI_API_KEY="your_openai_api_key_here"

# Node Environment
NODE_ENV="development"
